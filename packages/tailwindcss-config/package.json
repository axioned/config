{
  "name": "@axioned/tailwind-config",
  "version": "0.0.1",
  "type": "module",
  "description": "Axioned's shared Tailwind config",
  "repository": {
    "url": "git+https://github.com/axioned/config.git",
    "directory": "packages/tailwind-config"
  },
  "author": "Axioned (https://axioned.com)",
  "license": "MIT",
  "exports": {
    "./themes/default": {
      "style": "./themes/default.css",
      "default": "./themes/default.css"
    },
    "./postcss.config": "./postcss.config.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "tailwind",
    "tailwind-css",
    "tailwind-css-config"
  ],
  "peerDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/axioned/config/issues"
  },
  "homepage": "https://github.com/axioned/config#readme"
}
